	partition dCalendario = calculated
		mode: import
		source =
				
				VAR BaseCalendar = CALENDARAUTO() -- Ele olha todas as datas da sua base OLS Ecommerce
				RETURN
				ADDCOLUMNS (
				    BaseCalendar,
				    "Ano", YEAR([Date]),
				    "Mes Num", MONTH([Date]),
				    "Mes Nome", FORMAT([Date], "MMMM"),
				    "Trimestre", "Tri " & QUARTER([Date]),
				    "Dia Semana", FORMAT([Date], "dddd"),
				    "AnoMes", FORMAT([Date], "YYYY/MM")
				)

	annotation PBI_Id = 68498e8f197c4becb05c769f425185e5

