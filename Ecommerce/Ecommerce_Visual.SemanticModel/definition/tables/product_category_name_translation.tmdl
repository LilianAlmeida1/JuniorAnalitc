	column 'product_category_name (grupos)' =
			SWITCH(
				TRUE,
				ISBLANK('product_category_name_translation'[product_category_name]),
				"(Em branco)",
				'product_category_name_translation'[product_category_name] IN {"alimentos",
					"alimentos_bebidas",
					"bebidas"},
				"Alimentício",
				'product_category_name_translation'[product_category_name] IN {"cama_mesa_banho",
					"casa_conforto",
					"casa_conforto_2"},
				"Cama_Mesa_E_Banho",
				'product_category_name_translation'[product_category_name] IN {"artes",
					"artes_e_artesanato",
					"flores"},
				"Decoração",
				'product_category_name_translation'[product_category_name] IN {"audio",
					"tablets_impressao_imagem",
					"telefonia",
					"telefonia_fixa"},
				"Eletronicos",
				'product_category_name_translation'[product_category_name] IN {"livros_importados",
					"livros_interesse_geral",
					"livros_tecnicos"},
				"Livraria",
				'product_category_name_translation'[product_category_name] IN {"cds_dvds_musicais",
					"dvds_blu_ray",
					"musica"},
				"Mídias",
				'product_category_name_translation'[product_category_name] IN {"moveis_colchao_e_estofado",
					"moveis_cozinha_area_de_servico_jantar_e_jardim",
					"moveis_decoracao",
					"moveis_escritorio",
					"moveis_quarto",
					"moveis_sala"},
				"Moveis",
				'product_category_name_translation'[product_category_name] IN {"artigos_de_festas",
					"artigos_de_natal"},
				"Sazonalidades",
				'product_category_name_translation'[product_category_name]
			)
		lineageTag: f0c173ec-238d-4b28-99e8-8bdd7a74aeb8
		summarizeBy: none

